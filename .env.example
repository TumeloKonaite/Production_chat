# Application
APP_ENV=local
FRONTEND_ORIGIN=http://localhost:5173

# Docker Compose database bootstrap
POSTGRES_DB=production_chatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5051

# PostgreSQL and vector storage
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5434/production_chatbot
DATABASE_DIRECT_URL=
VECTOR_STORE_PROVIDER=pgvector

# Uploaded-file storage (local default: MinIO)
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-files
MINIO_SECURE=false
LOCAL_STORAGE_PATH=.storage
KNOWLEDGE_UPLOAD_MAX_BYTES=10485760

# Supabase (required only for a Supabase vector or storage provider)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=knowledge-files

# Chat model provider
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_PROMPT_COST_PER_1M_TOKENS=
LLM_COMPLETION_COST_PER_1M_TOKENS=
DEFAULT_MODEL_CONFIG_ID=openai:gpt-4.1-mini
MODEL_CONFIGS_JSON=

# Provider-specific compatibility variables
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embeddings and knowledge collection
EMBEDDING_PROVIDER=hf
KNOWLEDGE_EMBEDDING_MODEL=all-MiniLM-L6-v2
KNOWLEDGE_EMBEDDING_DIMENSION=384
# Legacy alias (prefer KNOWLEDGE_EMBEDDING_DIMENSION):
# EMBEDDING_DIMENSION=384
KNOWLEDGE_COLLECTION_NAME=personal_knowledge_base
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Prompting and retrieval
DEFAULT_PROMPT_VERSION=v1_professional
# Legacy alias (prefer DEFAULT_PROMPT_VERSION):
# PROMPT_VERSION=v1_professional
CONVERSATION_HISTORY_LIMIT=10
RETRIEVER_TYPE=vector
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SIMILARITY=0.55
DEFAULT_RETRIEVAL_CONFIG=default
ENABLE_QUERY_REWRITING=false
QUERY_REWRITE_MODEL=openai:gpt-4.1-mini
QUERY_REWRITE_TEMPERATURE=0.0
QUERY_REWRITE_PROMPT_VERSION=v1
QUERY_REWRITE_TIMEOUT_SECONDS=10
QUERY_REWRITE_MAX_TOKENS=128
ENABLE_RERANKING=false
RERANKER_TYPE=none
RERANKER_MODEL=openai:gpt-4.1-mini
RERANKER_INITIAL_TOP_K=20
RERANKER_FINAL_TOP_K=5

# Knowledge ingestion and protected evaluation APIs
INGESTION_API_SECRET=
INGESTION_BACKEND=local
MODAL_INGESTION_APP_NAME=production-chatbot-api
MODAL_INGESTION_FUNCTION_NAME=run_ingestion_job
EVAL_ADMIN_TOKEN=

# Upstash Redis operational cache, request lock, and fixed-window rate limit
ENABLE_REDIS=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
EXACT_CACHE_ENABLED=true
EXACT_CACHE_TTL_SECONDS=300
REQUEST_LOCK_ENABLED=true
REQUEST_LOCK_TTL_SECONDS=30

# Optional legacy Redis response-cache path
ENABLE_RESPONSE_CACHE=false
RESPONSE_CACHE_PROVIDER=redis
REDIS_URL=redis://localhost:6379/0
REDIS_TOKEN=
ENABLE_EXACT_RESPONSE_CACHE=true
ENABLE_SEMANTIC_RESPONSE_CACHE=false
RESPONSE_CACHE_TTL_SECONDS=604800
RESPONSE_CACHE_EXACT_PREFIX=chat:exact
RESPONSE_CACHE_SEMANTIC_INDEX=chat_semantic_cache
RESPONSE_CACHE_DISTANCE_THRESHOLD=0.10
RESPONSE_CACHE_MAX_RESULTS=3
RESPONSE_CACHE_STORE_PRIVATE_SESSIONS=false
RESPONSE_CACHE_KNOWLEDGE_BASE_VERSION=personal_knowledge_base

# Reserved granular rate-limit settings (not enforced by the current service)
ENABLE_RATE_LIMITING=false
RATE_LIMITING_FAIL_OPEN=true
CHAT_RATE_LIMIT_REQUESTS_PER_10_MINUTES=20
CHAT_RATE_LIMIT_REQUESTS_PER_DAY=100
CHAT_RATE_LIMIT_CONCURRENT_REQUESTS=3
CHAT_RATE_LIMIT_DAILY_TOKEN_BUDGET=100000
CHAT_RATE_LIMIT_DAILY_COST_BUDGET_USD=0.50

# Langfuse operational observability
ENABLE_LANGFUSE_OBSERVABILITY=false
# Legacy alias (prefer ENABLE_LANGFUSE_OBSERVABILITY):
# ENABLE_LANGFUSE=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENVIRONMENT=local
LANGFUSE_RELEASE=
LANGFUSE_SAMPLE_RATE=1.0
LANGFUSE_EXPORT_DEFAULT_LIMIT=100

# MLflow and optional DagsHub experiment tracking
ENABLE_MLFLOW_TRACKING=false
MLFLOW_TRACKING_URI=
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
MLFLOW_EXPERIMENT_NAME=personal-chatbot-model-comparison
ENABLE_DAGSHUB_TRACKING=false
DAGSHUB_REPO_OWNER=
DAGSHUB_REPO_NAME=
DAGSHUB_TOKEN=

# Feedback export and test-only integration settings
ENABLE_PRODUCTION_FEEDBACK_EXPORT=false
ALLOW_RAW_PRODUCTION_TEXT_IN_EVALS=false
RUN_DB_INTEGRATION_TESTS=false
TEST_DATABASE_URL=

# Production values belong in the deployment secret store, never in this file.
# APP_ENV=production requires FRONTEND_ORIGIN, DATABASE_URL, and a model API key.
